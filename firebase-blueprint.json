{
  "entities": {
    "School": {
      "title": "School",
      "description": "Educational institution in the multi-tenant system",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "User": {
      "title": "User",
      "description": "System user (Admin, Teacher, Student, Parent)",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student", "parent"] },
        "schoolId": { "type": "string" },
        "classId": { "type": "string", "description": "For students" },
        "teacherCode": { "type": "string", "description": "Used for bypass if needed" }
      },
      "required": ["email", "role", "schoolId"]
    },
    "Class": {
      "title": "Class",
      "description": "A group of students",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "schoolId": { "type": "string" },
        "teacherId": { "type": "string", "description": "Class curator" }
      },
      "required": ["name", "schoolId"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Academic subject",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "schoolId": { "type": "string" }
      },
      "required": ["name", "schoolId"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "A specific scheduled lesson instance",
      "type": "object",
      "properties": {
        "subjectId": { "type": "string" },
        "classId": { "type": "string" },
        "teacherId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "room": { "type": "string" },
        "type": { "type": "string", "enum": ["regular", "KR", "SR", "DZ"] },
        "topic": { "type": "string" }
      },
      "required": ["subjectId", "classId", "teacherId", "date"]
    },
    "Grade": {
      "title": "Grade",
      "description": "Student's grade for a subject",
      "type": "object",
      "properties": {
        "subjectId": { "type": "string" },
        "studentId": { "type": "string" },
        "value": { "type": "string" },
        "weight": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "schoolId": { "type": "string" }
      },
      "required": ["subjectId", "studentId", "value", "schoolId"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Student attendance record",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "schoolId": { "type": "string" }
      },
      "required": ["studentId", "date", "status", "schoolId"]
    }
  },
  "firestore": {
    "/schools/{schoolId}": { "schema": "School", "description": "School data" },
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/classes/{classId}": { "schema": "Class", "description": "School classes" },
    "/subjects/{subjectId}": { "schema": "Subject", "description": "School subjects" },
    "/lessons/{lessonId}": { "schema": "Lesson", "description": "Lesson instances" },
    "/grades/{gradeId}": { "schema": "Grade", "description": "Student grades" },
    "/attendance/{attendanceId}": { "schema": "Attendance", "description": "Attendance records" }
  }
}
